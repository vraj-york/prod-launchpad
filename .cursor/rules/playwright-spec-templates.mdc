### 4g. mobile.spec.ts
```typescript
import { test, expect, devices } from '@playwright/test';

const BASE_URL = process.env.BASE_URL || 'http://localhost:5173';

const MOBILE_VIEWPORTS = [
  { name: 'iPhone 14',       width: 390, height: 844  },
  { name: 'iPhone SE',       width: 375, height: 667  },
  { name: 'Android (360)',   width: 360, height: 800  },
  { name: 'iPad',            width: 768, height: 1024 },
];

for (const viewport of MOBILE_VIEWPORTS) {
  test.describe(`[FeatureName] — Mobile: ${viewport.name}`, () => {

    test.use({ viewport: { width: viewport.width, height: viewport.height } });

    test.beforeEach(async ({ page }) => {
      await page.route('**/api/[endpoint]', route =>
        route.fulfill({ status: 200, body: JSON.stringify([/* mock data */]) })
      );
      await page.goto(BASE_URL + '/[route]');
      await page.waitForLoadState('networkidle');
    });

    test('page renders correctly on mobile viewport', async ({ page }) => {
      await expect(page.getByRole('main')).toBeVisible();
    });

    test('hamburger menu visible and opens navigation', async ({ page }) => {
      const hamburger = page.getByRole('button', { name: /menu|hamburger/i });
      if (await hamburger.isVisible()) {
        await hamburger.click();
        await expect(page.getByRole('navigation')).toBeVisible();
      }
    });

    test('form fields not hidden behind soft keyboard', async ({ page }) => {
      const input = page.getByLabel(/[field label]/i);
      await input.tap();
      await expect(input).toBeInViewport();
    });

    test('modal renders as full-screen sheet on mobile', async ({ page }) => {
      await page.getByRole('button', { name: /[modal trigger]/i }).tap();
      const modal = page.getByRole('dialog');
      await expect(modal).toBeVisible();
      const box = await modal.boundingBox();
      expect(box?.width).toBeGreaterThanOrEqual(viewport.width * 0.9);
    });

    test('horizontal scroll works in overflow tables', async ({ page }) => {
      const table = page.getByRole('table');
      if (await table.isVisible()) {
        await expect(table).toBeVisible();
        // Table must be scrollable, not cut off
        const tableBox = await table.boundingBox();
        expect(tableBox).not.toBeNull();
      }
    });

    test('all primary action buttons are tap-target sized (>=44px)', async ({ page }) => {
      const buttons = page.getByRole('button');
      const count = await buttons.count();
      for (let i = 0; i < count; i++) {
        const box = await buttons.nth(i).boundingBox();
        if (box) {
          expect(box.height).toBeGreaterThanOrEqual(44);
        }
      }
    });
  });
}
