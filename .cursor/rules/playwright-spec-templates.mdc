### 4c. form.spec.ts
```typescript
import { test, expect } from '@playwright/test';

const BASE_URL = process.env.BASE_URL || 'http://localhost:5173';

test.describe('[FeatureName] — Form Tests', () => {

  test.beforeEach(async ({ page }) => {
    await page.goto(BASE_URL + '/[route]');
    await page.waitForLoadState('networkidle');
  });

  // ── Required field validation ──────────────────────────────────────
  test('submit empty form shows all required field errors', async ({ page }) => {
    await page.getByRole('button', { name: /submit|save|create/i }).click();
    // Assert one error per required field found in analysis card
    await expect(page.getByText(/[field name] is required/i)).toBeVisible();
  });

  // ── Field-level validation (generate one block per input) ──────────
  test('[fieldName]: empty value shows required error', async ({ page }) => {
    await page.getByLabel(/[field label]/i).clear();
    await page.getByRole('button', { name: /submit/i }).click();
    await expect(page.getByText(/[field] is required/i)).toBeVisible();
  });

  test('[fieldName]: invalid format shows format error', async ({ page }) => {
    await page.getByLabel(/[field label]/i).fill('[invalid value from dummy data plan]');
    await page.getByRole('button', { name: /submit/i }).click();
    await expect(page.getByText(/invalid [field]/i)).toBeVisible();
  });

  test('[fieldName]: valid value clears error', async ({ page }) => {
    await page.getByLabel(/[field label]/i).fill('[invalid value]');
    await page.getByRole('button', { name: /submit/i }).click();
    await expect(page.getByText(/invalid/i)).toBeVisible();
    await page.getByLabel(/[field label]/i).fill('[valid value]');
    await expect(page.getByText(/invalid/i)).not.toBeVisible();
  });

  // ── Happy path ─────────────────────────────────────────────────────
  test('valid form submission succeeds', async ({ page }) => {
    await page.route('**/api/[endpoint]', route =>
      route.fulfill({ status: 201, body: JSON.stringify({ id: 1, success: true }) })
    );
    // Fill every field with valid values from dummy data plan
    await page.getByLabel(/[field1 label]/i).fill('[valid value 1]');
    await page.getByLabel(/[field2 label]/i).fill('[valid value 2]');
    await page.getByRole('button', { name: /submit/i }).click();
    await expect(page.getByText(/success|saved|created/i)).toBeVisible();
  });

  // ── Edge cases ─────────────────────────────────────────────────────
  test('submit by pressing Enter key works', async ({ page }) => {
    await page.getByLabel(/[field label]/i).fill('[valid value]');
    await page.keyboard.press('Enter');
    await expect(page.getByText(/success/i)).toBeVisible();
  });

  test('double-click submit does not create duplicate', async ({ page }) => {
    let callCount = 0;
    await page.route('**/api/[endpoint]', route => {
      callCount++;
      return route.fulfill({ status: 201, body: JSON.stringify({ id: callCount }) });
    });
    await page.getByLabel(/[field label]/i).fill('[valid value]');
    await page.getByRole('button', { name: /submit/i }).dblclick();
    await page.waitForTimeout(500);
    expect(callCount).toBe(1);
  });

  test('whitespace-only input treated as empty', async ({ page }) => {
    await page.getByLabel(/[field label]/i).fill('     ');
    await page.getByRole('button', { name: /submit/i }).click();
    await expect(page.getByText(/required/i)).toBeVisible();
  });

  test('pasting data into fields triggers validation', async ({ page }) => {
    await page.getByLabel(/[email label]/i).fill('');
    await page.evaluate(() => {
      const input = document.querySelector('input[type="email"]') as HTMLInputElement;
      if (input) { input.value = 'invalid-paste'; input.dispatchEvent(new Event('input')); }
    });
    await page.getByRole('button', { name: /submit/i }).click();
    await expect(page.getByText(/invalid/i)).toBeVisible();
  });

  test('1000-character input does not crash the form', async ({ page }) => {
    const longString = 'a'.repeat(1000);
    await page.getByLabel(/[field label]/i).fill(longString);
    await expect(page.getByLabel(/[field label]/i)).toBeVisible();
  });

  test('special characters in fields are handled gracefully', async ({ page }) => {
    await page.getByLabel(/[field label]/i).fill('!@#$%^&*()<>?/\\|{}~`');
    await page.getByRole('button', { name: /submit/i }).click();
    // Should either accept or show a clean error — never crash
    await expect(page).not.toHaveURL(/error|500/);
  });
});
```

