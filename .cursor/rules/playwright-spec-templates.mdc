import { test, expect } from '@playwright/test';

const BASE_URL = process.env.BASE_URL || 'http://localhost:5173';

test.describe('[FeatureName] — API Mock Tests', () => {

  // ── Success states ────────────────────────────────────────────────
  test('renders data correctly on API success (200)', async ({ page }) => {
    await page.route('**/api/[endpoint]', route =>
      route.fulfill({
        status: 200,
        body: JSON.stringify([
          { id: 1, [field]: '[realistic value 1]' },
          { id: 2, [field]: '[realistic value 2]' }
        ])
      })
    );
    await page.goto(BASE_URL + '/[route]');
    await expect(page.getByText('[realistic value 1]')).toBeVisible();
  });

  // ── Error states (generate one per API call found) ─────────────────
  test('shows error UI on server error (500)', async ({ page }) => {
    await page.route('**/api/[endpoint]', route =>
      route.fulfill({ status: 500, body: JSON.stringify({ message: 'Internal Server Error' }) })
    );
    await page.goto(BASE_URL + '/[route]');
    await expect(page.getByRole('alert')).toBeVisible();
    await expect(page.getByText(/something went wrong|error/i)).toBeVisible();
  });

  test('shows error UI on not found (404)', async ({ page }) => {
    await page.route('**/api/[endpoint]', route =>
      route.fulfill({ status: 404, body: JSON.stringify({ message: 'Not Found' }) })
    );
    await page.goto(BASE_URL + '/[route]');
    await expect(page.getByText(/not found|no data/i)).toBeVisible();
  });

  test('shows error UI on unauthorized (401)', async ({ page }) => {
    await page.route('**/api/[endpoint]', route =>
      route.fulfill({ status: 401, body: JSON.stringify({ message: 'Unauthorized' }) })
    );
    await page.goto(BASE_URL + '/[route]');
    await expect(page).toHaveURL(/login|signin/);
  });

  test('shows error UI on network failure', async ({ page }) => {
    await page.route('**/api/[endpoint]', route => route.abort('failed'));
    await page.goto(BASE_URL + '/[route]');
    await expect(page.getByText(/network error|failed to load/i)).toBeVisible();
  });

  test('shows loading spinner during slow API response', async ({ page }) => {
    await page.route('**/api/[endpoint]', route =>
      new Promise(resolve => setTimeout(() => resolve(route.continue()), 2000))
    );
    const gotoPromise = page.goto(BASE_URL + '/[route]');
    await expect(page.getByTestId('spinner')).toBeVisible();
    // TODO: add data-testid="spinner" to loading indicator element
    await gotoPromise;
  });

  test('correct request payload sent on form submit', async ({ page }) => {
    let capturedBody: Record<string, unknown> = {};
    await page.route('**/api/[endpoint]', async route => {
      const request = route.request();
      capturedBody = JSON.parse(request.postData() || '{}');
      await route.fulfill({ status: 201, body: JSON.stringify({ id: 99 }) });
    });
    await page.goto(BASE_URL + '/[route]');
    await page.getByLabel(/[field label]/i).fill('[valid value]');
    await page.getByRole('button', { name: /submit/i }).click();
    expect(capturedBody).toMatchObject({ [fieldKey]: '[valid value]' });
  });

  test('empty API response shows empty state UI', async ({ page }) => {
    await page.route('**/api/[endpoint]', route =>
      route.fulfill({ status: 200, body: JSON.stringify([]) })
    );
    await page.goto(BASE_URL + '/[route]');
    await expect(page.getByText(/no [items]|empty/i)).toBeVisible();
  });
});
