### 4h. accessibility.spec.ts
```typescript
import { test, expect } from '@playwright/test';

const BASE_URL = process.env.BASE_URL || 'http://localhost:5173';

test.describe('[FeatureName] — Accessibility', () => {

  test.beforeEach(async ({ page }) => {
    await page.route('**/api/[endpoint]', route =>
      route.fulfill({ status: 200, body: JSON.stringify([/* mock data */]) })
    );
    await page.goto(BASE_URL + '/[route]');
    await page.waitForLoadState('networkidle');
  });

  test('page has exactly one h1 heading', async ({ page }) => {
    const h1Count = await page.getByRole('heading', { level: 1 }).count();
    expect(h1Count).toBe(1);
  });

  test('all interactive elements reachable via Tab key', async ({ page }) => {
    const interactiveElements = page.locator('button, a, input, select, textarea, [tabindex]');
    const count = await interactiveElements.count();
    for (let i = 0; i < count; i++) {
      const tabIndex = await interactiveElements.nth(i).getAttribute('tabindex');
      expect(tabIndex).not.toBe('-1');
    }
  });

  test('form fields have associated labels', async ({ page }) => {
    const inputs = page.locator('input:not([type="hidden"]), select, textarea');
    const count = await inputs.count();
    for (let i = 0; i < count; i++) {
      const id = await inputs.nth(i).getAttribute('id');
      const ariaLabel = await inputs.nth(i).getAttribute('aria-label');
      const ariaLabelledBy = await inputs.nth(i).getAttribute('aria-labelledby');
      const hasLabel = id
        ? (await page.locator(`label[for="${id}"]`).count()) > 0
        : false;
      expect(hasLabel || ariaLabel || ariaLabelledBy).toBeTruthy();
    }
  });

  test('icon-only buttons have aria-label', async ({ page }) => {
    const iconButtons = page.locator('button:has(svg):not(:has(span))');
    const count = await iconButtons.count();
    for (let i = 0; i < count; i++) {
      const label = await iconButtons.nth(i).getAttribute('aria-label');
      expect(label).not.toBeNull();
    }
  });

  test('all images have non-empty alt text', async ({ page }) => {
    const images = page.locator('img');
    const count = await images.count();
    for (let i = 0; i < count; i++) {
      const alt = await images.nth(i).getAttribute('alt');
      expect(alt).not.toBeNull();
    }
  });

  test('modal traps focus when open', async ({ page }) => {
    await page.getByRole('button', { name: /[modal trigger]/i }).click();
    const modal = page.getByRole('dialog');
    await expect(modal).toBeVisible();
    await page.keyboard.press('Tab');
    const focused = page.locator(':focus');
    // Focus must stay inside modal
    await expect(modal.locator(':focus')).toBeVisible();
  });

  test('pressing Escape closes modal', async ({ page }) => {
    await page.getByRole('button', { name: /[modal trigger]/i }).click();
    await expect(page.getByRole('dialog')).toBeVisible();
    await page.keyboard.press('Escape');
    await expect(page.getByRole('dialog')).not.toBeVisible();
  });

  test('error messages linked to inputs via aria-describedby', async ({ page }) => {
    await page.getByRole('button', { name: /submit/i }).click();
    const inputsWithErrors = page.locator('input[aria-describedby]');
    const count = await inputsWithErrors.count();
    expect(count).toBeGreaterThan(0);
    // TODO: ensure all input error messages use aria-describedby
  });
});
```
