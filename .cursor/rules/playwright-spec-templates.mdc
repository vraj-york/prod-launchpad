import { test, expect } from '@playwright/test';

const BASE_URL = process.env.BASE_URL || 'http://localhost:5173';

test.describe('[FeatureName] — Edge Cases', () => {

  test('handles extremely long text without layout overflow', async ({ page }) => {
    await page.route('**/api/[endpoint]', route =>
      route.fulfill({
        status: 200,
        body: JSON.stringify([{ id: 1, [field]: 'A'.repeat(500) }])
      })
    );
    await page.goto(BASE_URL + '/[route]');
    const container = page.getByTestId('[container-testid]');
    // TODO: add data-testid="[container-testid]" to main container
    const box = await container.boundingBox();
    expect(box?.width).toBeLessThanOrEqual(1280);
  });

  test('handles special characters in displayed data', async ({ page }) => {
    await page.route('**/api/[endpoint]', route =>
      route.fulfill({
        status: 200,
        body: JSON.stringify([{ id: 1, [field]: '<script>alert("xss")</script>' }])
      })
    );
    await page.goto(BASE_URL + '/[route]');
    // Script tag must NOT execute — must be escaped
    const alertFired = await page.evaluate(() => {
      return (window as unknown as { __alertFired?: boolean }).__alertFired === true;
    });
    expect(alertFired).toBeFalsy();
  });

  test('browser back/forward navigation restores correct state', async ({ page }) => {
    await page.goto(BASE_URL + '/[route]');
    await page.getByRole('link', { name: /[link]/i }).click();
    await page.goBack();
    await expect(page).toHaveURL(BASE_URL + '/[route]');
  });

  test('rapid repeated clicks do not cause duplicate actions', async ({ page }) => {
    let count = 0;
    await page.route('**/api/[endpoint]', route => { count++; return route.fulfill({ status: 200 }); });
    const button = page.getByRole('button', { name: /[action]/i });
    await button.click();
    await button.click();
    await button.click();
    await page.waitForTimeout(300);
    expect(count).toBe(1);
  });

  test('single item in list renders correctly (no plural issues)', async ({ page }) => {
    await page.route('**/api/[endpoint]', route =>
      route.fulfill({ status: 200, body: JSON.stringify([{ id: 1, [field]: '[value]' }]) })
    );
    await page.goto(BASE_URL + '/[route]');
    await expect(page.getByText('[value]')).toBeVisible();
  });

  test('1000 items in list does not crash or freeze', async ({ page }) => {
    const items = Array.from({ length: 1000 }, (_, i) => ({ id: i + 1, [field]: `Item ${i + 1}` }));
    await page.route('**/api/[endpoint]', route =>
      route.fulfill({ status: 200, body: JSON.stringify(items) })
    );
    await page.goto(BASE_URL + '/[route]');
    await expect(page.getByRole('main')).toBeVisible();
  });
});
